function TBSCertificate_Equal (val1, val2 :  TBSCertificate) return Boolean
is
    pragma Warnings (Off, "initialization of ""ret"" has no effect");
    ret : Boolean := True;
    pragma Warnings (On, "initialization of ""ret"" has no effect");

begin
    ret := val1.Exist.ver = val2.Exist.ver;
    if ret and then val1.Exist.ver = 1 then
        ret := (val1.ver = val2.ver);
    end if;

    if ret then
        ret := (val1.serialNumber = val2.serialNumber);

        if ret then
            ret := AlgorithmIdentifier_Equal(val1.signature, val2.signature);

            if ret then
                ret := Name_Equal(val1.issuer, val2.issuer);

                if ret then
                    ret := Validity_Equal(val1.valid, val2.valid);

                    if ret then
                        ret := Name_Equal(val1.subject, val2.subject);

                        if ret then
                            ret := SubjectPublicKeyInfo_Equal(val1.subjectPubKeyInfo, val2.subjectPubKeyInfo);

                            if ret then
                                ret := val1.Exist.issuerUniqueID = val2.Exist.issuerUniqueID;
                                if ret and then val1.Exist.issuerUniqueID = 1 then
                                    ret := UniqueIdentifier_Equal(val1.issuerUniqueID, val2.issuerUniqueID);
                                end if;

                                if ret then
                                    ret := val1.Exist.subjectUniqueID = val2.Exist.subjectUniqueID;
                                    if ret and then val1.Exist.subjectUniqueID = 1 then
                                        ret := UniqueIdentifier_Equal(val1.subjectUniqueID, val2.subjectUniqueID);
                                    end if;

                                    if ret then
                                        ret := val1.Exist.exts = val2.Exist.exts;
                                        if ret and then val1.Exist.exts = 1 then
                                            ret := Extensions_Equal(val1.exts, val2.exts);
                                        end if;

                                    end if;
                                end if;
                            end if;
                        end if;
                    end if;
                end if;
            end if;
        end if;
    end if;
	return ret;

end TBSCertificate_Equal;

