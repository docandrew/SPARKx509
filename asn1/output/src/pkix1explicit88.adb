    if ret.Success then
        ret := CertificateSerialNumber_IsConstraintValid(val.serialNumber);
        if ret.Success then
            ret := AlgorithmIdentifier_IsConstraintValid(val.signature);
            if ret.Success then
                ret := Name_IsConstraintValid(val.issuer);
                if ret.Success then
                    ret := Validity_IsConstraintValid(val.valid);
                    if ret.Success then
                        ret := Name_IsConstraintValid(val.subject);
                        if ret.Success then
                            ret := SubjectPublicKeyInfo_IsConstraintValid(val.subjectPubKeyInfo);
                            if ret.Success then
                                if val.Exist.issuerUniqueID = 1 then
                                    ret := UniqueIdentifier_IsConstraintValid(val.issuerUniqueID);
                                end if;
                                if ret.Success then
                                    if val.Exist.subjectUniqueID = 1 then
