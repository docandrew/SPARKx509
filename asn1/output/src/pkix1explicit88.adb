                                    end if;
                                    if ret.Success then
                                        if val.Exist.exts = 1 then
                                            ret := Extensions_IsConstraintValid(val.exts);
                                        end if;
                                    end if;
                                end if;
                            end if;
                        end if;
                    end if;
                end if;
            end if;
        end if;
