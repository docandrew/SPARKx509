with "../../sparkx509.gpr";

project Smoke is
   for Create_Missing_Dirs use "True";
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Source_Dirs use (".");
   for Main use ("smoke_x509.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        ("-g", "-Og", "-gnata", "-gnat2022");
   end Compiler;
end Smoke;

